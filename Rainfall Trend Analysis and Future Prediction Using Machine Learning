print("-" * 100)

mean_annual = annual_totals['Annual_Total_mm'].mean()
std_annual = annual_totals['Annual_Total_mm'].std()

annual_totals['Anomaly_mm'] = annual_totals['Annual_Total_mm'] - mean_annual
annual_totals['Std_Anomaly'] = (annual_totals['Annual_Total_mm'] - mean_annual) / std_annual
annual_totals['Anomaly_Pct'] = (annual_totals['Anomaly_mm'] / mean_annual) * 100

def classify_anomaly(std_val):
    if std_val > 1:
        return 'Very Wet'
    elif std_val > 0.5:
        return 'Wet'
    elif std_val > -0.5:
        return 'Normal'
    elif std_val > -1:
        return 'Dry'
    else:
        return 'Very Dry'

annual_totals['Class'] = annual_totals['Std_Anomaly'].apply(classify_anomaly)

