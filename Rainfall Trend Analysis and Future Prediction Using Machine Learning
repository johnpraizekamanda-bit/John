# ========================================
# TABLE 4: DECADAL ANALYSIS
# ========================================
print("\n" + "=" * 100)
print("TABLE 4: DECADAL RAINFALL ANALYSIS")
print("=" * 100)

def assign_decade(year):
    """Assign decade label"""
    if 1991 <= year <= 2000:
        return '1991-2000'
    elif 2001 <= year <= 2010:
        return '2001-2010'
    elif 2011 <= year <= 2020:
        return '2011-2020'
    else:
        return '2021-2025'

df_historical['Decade'] = df_historical['Year'].apply(assign_decade)

decadal_analysis = df_historical.groupby(['Decade', 'Season'])['Precipitation_mm'].agg([
    'sum', 'mean', 'std', 'count'
]).round(2).reset_index()

decadal_analysis.columns = ['Decade', 'Season', 'Total_mm', 'Mean_Daily_mm', 'Std_mm', 'Days']

